            "items": { "$ref": "#/components/schemas/ChunkInfo" },
            "type": "array",
            "title": "Chunks"
          }
        },
        "type": "object",
        "required": ["filename", "total_chunks", "chunks"],
        "title": "DocumentChunksResponse",
        "description": "文档切片列表响应模型"
      },
      "HTTPValidationError": {
